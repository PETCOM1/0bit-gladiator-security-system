# =============================================================================
# ENVIRONMENT VARIABLES — 0bit Web App Template
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# The variable NAMES never change — only the VALUES differ per provider.
# =============================================================================


# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Choose one database provider. Paste the connection string into DATABASE_URL.
#
# POSTGRESQL options:
#   Supabase (recommended):
#     DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#     DIRECT_URL=postgresql://postgres:[pass]@db.[ref].supabase.co:5432/postgres
#
#   Railway (auto-injected — no action needed, Railway sets DATABASE_URL):
#     DATABASE_URL=${{RAILWAY_DATABASE_URL}}
#
#   Render:
#     DATABASE_URL=postgresql://user:pass@dpg-xxxxxxx.render.com/dbname
#
#   AWS RDS:
#     DATABASE_URL=postgresql://user:pass@xxx.rds.amazonaws.com:5432/dbname
#
# MONGODB option (if you switch ORM to Mongoose):
#   MongoDB Atlas:
#     DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true
#
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres


# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars


# ─── URLS ─────────────────────────────────────────────────────────────────────
# Development
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Production — update per deployment target:
#   Vercel web:    FRONTEND_URL=https://your-app.vercel.app
#   Railway API:   API_URL=https://your-api.railway.app
#   Render API:    API_URL=https://your-api.onrender.com
#   AWS API GW:    API_URL=https://xxx.execute-api.eu-west-1.amazonaws.com/prod


# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Authorised redirect URIs:
#   Dev:  http://localhost:3001/api/v1/auth/google/callback
#   Prod: https://your-api.railway.app/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# ─── EMAIL ────────────────────────────────────────────────────────────────────
# Resend (recommended, generous free tier): https://resend.com
RESEND_API_KEY=re_your_key_here
SENDER_EMAIL=noreply@yourdomain.com
#
# Alternative providers — swap in your own mail service:
#   SendGrid: use @sendgrid/mail npm package
#   AWS SES:  use @aws-sdk/client-ses npm package
#   Postmark: use postmark npm package


# ─── AI ───────────────────────────────────────────────────────────────────────
# Anthropic Claude — used for document generation and AI workers
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here


# ─── FILE STORAGE ─────────────────────────────────────────────────────────────
# Choose one storage provider for file uploads (images, documents, audio).
#
# Cloudflare R2 (recommended — S3-compatible, free egress):
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
#
# AWS S3 (swap R2_ vars above for S3_ and update the SDK calls in code):
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_REGION=eu-west-1
#   AWS_BUCKET_NAME=
#   AWS_CLOUDFRONT_DOMAIN=   (if using CloudFront CDN)
#
# Supabase Storage (simplest if already using Supabase DB):
#   Uses SUPABASE_URL + SUPABASE_SERVICE_KEY — no extra vars needed


# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001


# =============================================================================
# CI/CD — GitHub Actions Secrets
# =============================================================================
# Add these in: GitHub repo → Settings → Secrets and variables → Actions
#
# Required for CI (type check + build):
#   DATABASE_URL        → same as above
#   JWT_SECRET          → same as above
#   NEXT_PUBLIC_API_URL → same as above
#
# Required for auto-deploy to Vercel (web):
#   VERCEL_TOKEN        → vercel.com → Account Settings → Tokens
#   VERCEL_ORG_ID       → vercel.com → Team Settings → General
#   VERCEL_PROJECT_ID   → vercel.com → Project Settings → General
#
# Required for auto-deploy to Railway (API):
#   RAILWAY_TOKEN       → railway.app → Account → Tokens
#
# Alternative deploy targets:
#   Render:    Use render.yaml in repo root + RENDER_API_KEY secret
#   AWS:       Use AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY + CDK/SAM
# =============================================================================
